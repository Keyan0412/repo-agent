# Copy this file to `.env` and fill in your Bailian credentials.

# Bailian / DashScope API key
DASHSCOPE_API_KEY=sk-your-api-key-here

# Beijing region by default. Official docs list these compatible-mode base URLs:
# Beijing: https://dashscope.aliyuncs.com/compatible-mode/v1
# Virginia: https://dashscope-us.aliyuncs.com/compatible-mode/v1
# Singapore: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Default model for repo-agent. Example from the official docs: qwen-plus
REPO_AGENT_MODEL=qwen-plus

# Bailian's OpenAI-compatible API supports the non-standard `enable_thinking`
# parameter via `extra_body`. Keep it off by default.
REPO_AGENT_ENABLE_THINKING=false
